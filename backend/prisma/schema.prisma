generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
}

enum UserRole {
  PARENT
  VENDOR
  SCHOOL_ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  TOPUP
  CHARGE
  REFUND
  ADJUSTMENT
}

enum TopupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NutritionalLevel {
  LEVEL_1  // Sin sellos â€” producto ideal
  LEVEL_2  // Con advertencias
}

// Forma fisicoquimica del producto (Art. 4 Res. 2492/2022)
// Define el umbral de sodio aplicable en la clasificacion nutricional
enum ProductForm {
  SOLID       // Solido convencional: umbral sodio >= 300 mg/100g
  LIQUID      // Liquido convencional: umbral sodio >= 40 mg/100ml
  SEMI_SOLID  // Yogur, pure, crema: umbral sodio >= 100 mg/100g
  POWDER      // Polvo (avena, saborizante): umbral sodio >= 400 mg/100g
  GEL         // Gel comestible (gelatina): umbral sodio >= 100 mg/100g
}

// Tipo de producto — Brecha #2
// Segmento de edad - Brecha #4
enum AgeSegment {
  PRESCHOOL
  PRIMARY
  SECONDARY
  ALL_AGES
}

enum ProductType {
  FOOD
  DRINK
  SNACK
  SUPPLEMENT
  COMBO
}

model School {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(200)
  nit        String?  @unique @db.VarChar(20)
  city       String   @db.VarChar(100)
  department String?  @db.VarChar(100) // Departamento (e.g. "Antioquia")
  address    String?  @db.Text
  phone        String?  @db.VarChar(20)
  country_code String?  @default("+57") @db.VarChar(5)
  email        String?  @db.VarChar(255)
  logo_url   String?  @db.Text
  plan       PlanType @default(BASIC)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  users          User[]
  students       Student[]
  stores         Store[]
  lunch_orders   LunchOrder[]
  transactions   Transaction[]
  topup_requests TopupRequest[]
  chat_threads   ChatThread[]
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  school_id     String?  @db.Uuid
  email         String   @unique @db.VarChar(255)
  phone         String?  @db.VarChar(20)
  country_code  String?  @default("+57") @db.VarChar(5)
  password_hash String?  @db.Text
  google_id     String?  @unique @db.VarChar(100)
  auth_provider String   @default("local") @db.VarChar(20)
  role          UserRole
  full_name     String   @db.VarChar(200)
  avatar_url    String?  @db.Text
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // â”€â”€ Ley 1581/2012 â€” Habeas Data â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // Consentimiento en 3 capas (Art. 7, 9, 12)
  consent_general      Boolean  @default(false)  // AutorizaciÃ³n general tratamiento
  consent_sensitive    Boolean  @default(false)  // AutorizaciÃ³n datos sensibles (alergias/salud)
  consent_legal_rep    Boolean  @default(false)  // DeclaraciÃ³n representaciÃ³n legal del menor
  consent_timestamp    DateTime?                 // CuÃ¡ndo se otorgaron los consentimientos
  consent_version      String?  @db.VarChar(20) // VersiÃ³n polÃ­tica aceptada (ej: "v1.0")
  consent_ip           String?  @db.VarChar(45) // IP de quien consintiÃ³
  // OposiciÃ³n granular (Derecho de OposiciÃ³n â€” Art. 13)
  allow_analytics      Boolean  @default(true)  // Uso datos para anÃ¡lisis de servicio
  allow_marketing      Boolean  @default(false) // Comunicaciones comerciales
  // Derecho al Olvido (Art. 8, 15)
  deletion_requested   Boolean  @default(false) // Solicitud de eliminaciÃ³n pendiente
  deletion_requested_at DateTime?               // CuÃ¡ndo se solicitÃ³
  deletion_executed_at  DateTime?               // CuÃ¡ndo se ejecutÃ³ la eliminaciÃ³n
  anonymized           Boolean  @default(false) // Registro anonimizado

  school         School?             @relation(fields: [school_id], references: [id])
  students       Student[]           @relation("ParentToStudent")
  deliveries     LunchOrder[]        @relation("DeliveredBy")
  refresh_tokens   RefreshToken[]
  reset_tokens     PasswordResetToken[]
  topup_requests   TopupRequest[]
  push_subscriptions PushSubscription[]
  audit_logs       AuditLog[]
  vendor_threads   ChatThread[]       @relation("VendorThreads")
  parent_threads   ChatThread[]       @relation("ParentThreads")
  sent_messages    ChatMessage[]
}


model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.Text
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([token_hash])
}

model Student {
  id          String   @id @default(uuid()) @db.Uuid
  school_id   String   @db.Uuid
  parent_id   String   @db.Uuid
  national_id String?  @db.VarChar(20)
  full_name   String   @db.VarChar(200)
  grade       String?  @db.VarChar(10)
  photo_url   String?  @db.Text
  balance     Decimal  @default(0.00) @db.Decimal(10, 2)
  delivery_code String? @db.VarChar(6)
  daily_spending_limit Decimal @default(15000.00) @db.Decimal(10, 2)
  active      Boolean  @default(true)
  created_at  DateTime @default(now())

  school         School        @relation(fields: [school_id], references: [id])
  parent         User          @relation("ParentToStudent", fields: [parent_id], references: [id])
  lunch_orders   LunchOrder[]
  transactions   Transaction[]
  topup_requests TopupRequest[]
  allergies      StudentAllergy[]
  nutrition_reports NutritionDailyReport[]

  @@unique([school_id, national_id])
}

model Store {
  id         String   @id @default(uuid()) @db.Uuid
  school_id  String   @db.Uuid
  name       String   @db.VarChar(200)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  school         School         @relation(fields: [school_id], references: [id])
  lunch_orders   LunchOrder[]
  store_products StoreProduct[]
}

// CategorÃ­as de productos â€” CRUD dinÃ¡mico
model ProductCategory {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique @db.VarChar(50)   // slug: "almuerzo", "bebida", etc.
  label      String   @db.VarChar(100)           // display: "Almuerzos", "Bebidas"
  icon       String?  @db.VarChar(10)            // emoji icon
  color      String?  @db.VarChar(20)            // hex color
  sort_order Int      @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  products   Product[] // relaciÃ³n inversa â€” FK category_id en Product
}

// CatÃ¡logo maestro global â€” administrado por SUPER_ADMIN
model Product {
  id                   String          @id @default(uuid()) @db.Uuid
  name                 String          @db.VarChar(200)
  description          String?         @db.Text
  base_price           Decimal         @db.Decimal(10, 2)
  image_url            String?         @db.Text
  // â”€â”€ ClasificaciÃ³n de categorÃ­a â€” Brecha #1 corregida â”€â”€
  category             String?         @db.VarChar(50)  // @deprecated â€” legacy slug; usar category_id
  category_id          String?         @db.Uuid         // FK formal a ProductCategory
  // -- Tipo de producto -- Brecha #2 corregida
  product_type         ProductType     @default(FOOD)
  // -- Segmento de edad -- Brecha #4 corregida
  age_segment          AgeSegment      @default(ALL_AGES)  // FOOD|DRINK|SNACK|SUPPLEMENT|COMBO
  is_healthy           Boolean         @default(true)
  customizable_options String[]        @default([])

  // â”€â”€ Ley 2120 / ResoluciÃ³n 2492 de 2022 â”€â”€
  product_form           ProductForm     @default(SOLID)
  nutritional_level      NutritionalLevel @default(LEVEL_1) // computado por NutritionalClassifier
  sodium_per_100         Decimal?        @db.Decimal(8, 2)  // mg por 100g o 100ml
  added_sugars_pct       Decimal?        @db.Decimal(5, 2)  // % energÃ­a azÃºcares aÃ±adidos
  saturated_fat_pct      Decimal?        @db.Decimal(5, 2)  // % energÃ­a grasas saturadas
  trans_fat_pct          Decimal?        @db.Decimal(5, 2)  // % energÃ­a grasas trans
  has_sweeteners         Boolean         @default(false)
  // Sellos computados (solo escritura por NutritionalClassifier)
  seal_sodium            Boolean         @default(false)
  seal_sugars            Boolean         @default(false)
  seal_saturated_fat     Boolean         @default(false)
  seal_trans_fat         Boolean         @default(false)
  seal_sweeteners        Boolean         @default(false)
  // Trazabilidad
  // -- Porcion nutricional -- Brecha #5 corregida
  // Art. 6 Res. 2492/2022: etiquetado nutricional referenciado por porcion
  serving_size_g        Decimal?        @db.Decimal(8, 2)  // gramos por porcion (solidos/semis.)
  serving_size_ml       Decimal?        @db.Decimal(8, 2)  // ml por porcion (liquidos, geles)
  servings_per_package  Decimal?        @db.Decimal(6, 1)  // porciones por empaque
  
  supplier_id           String?         @db.Uuid            // FK a Supplier -- Brecha #6
    supplier_tech_sheet_url String?        @db.VarChar(500)
  last_nutritional_audit  DateTime?

  active               Boolean         @default(true)
  created_at           DateTime        @default(now())

  supplier_rel   Supplier?        @relation(fields: [supplier_id], references: [id])
    category_rel   ProductCategory? @relation(fields: [category_id], references: [id])
  store_products StoreProduct[]
  allergens      ProductAllergy[]
}

// Pivot: quÃ© productos ofrece cada tienda, con precio y stock propios
model StoreProduct {
  id         String   @id @default(uuid()) @db.Uuid
  store_id   String   @db.Uuid
  product_id String   @db.Uuid
  price      Decimal? @db.Decimal(10, 2)  // null = usar base_price del catÃ¡logo
  stock      Int?                          // null = sin lÃ­mite
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  store       Store       @relation(fields: [store_id], references: [id])
  product     Product     @relation(fields: [product_id], references: [id])
  order_items OrderItem[]

  @@unique([store_id, product_id])
}

model LunchOrder {
  id             String      @id @default(uuid()) @db.Uuid
  school_id      String      @db.Uuid
  student_id     String      @db.Uuid
  store_id       String      @db.Uuid
  scheduled_date DateTime    @db.Date
  status         OrderStatus @default(PENDING)
  total_amount   Decimal     @db.Decimal(10, 2)
  delivered_at   DateTime?
  delivered_by   String?     @db.Uuid
  otp_verified   Boolean     @default(false)
  otp_code       String?     @db.VarChar(6)
  otp_expires_at DateTime?
  notes          String?     @db.Text
  // â”€â”€ Ley 2120 compliance â”€â”€
  is_seal_free        Boolean  @default(false)  // todos los productos level_1
  has_sweetener_alert Boolean  @default(false)  // algÃºn producto con edulcorantes
  seal_summary        Json     @default("{}")
  compliance_score    Int      @default(100)    // 0-100
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  school      School        @relation(fields: [school_id], references: [id])
  student     Student       @relation(fields: [student_id], references: [id])
  store       Store         @relation(fields: [store_id], references: [id])
  deliverer   User?         @relation("DeliveredBy", fields: [delivered_by], references: [id])
  order_items OrderItem[]
  Transaction Transaction[]
  chat_threads ChatThread[]
}

model OrderItem {
  id               String  @id @default(uuid()) @db.Uuid
  order_id         String  @db.Uuid
  store_product_id String  @db.Uuid
  quantity         Int     @default(1) @db.SmallInt
  unit_price       Decimal @db.Decimal(10, 2)
  subtotal         Decimal @db.Decimal(10, 2)
  customizations   String[] @default([])

  order         LunchOrder   @relation(fields: [order_id], references: [id])
  store_product StoreProduct @relation(fields: [store_product_id], references: [id])
}

model Transaction {
  id             String          @id @default(uuid()) @db.Uuid
  school_id      String          @db.Uuid
  student_id     String          @db.Uuid
  type           TransactionType
  amount         Decimal         @db.Decimal(10, 2)
  balance_after  Decimal         @db.Decimal(10, 2)
  payment_method String?         @db.VarChar(50)
  gateway_ref    String?         @db.VarChar(100)
  order_id       String?         @db.Uuid
  created_at     DateTime        @default(now())

  school  School      @relation(fields: [school_id], references: [id])
  student Student     @relation(fields: [student_id], references: [id])
  order   LunchOrder? @relation(fields: [order_id], references: [id])
}

model PasswordResetToken {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @db.Text
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([token_hash])
}

model TopupRequest {
  id                    String             @id @default(uuid()) @db.Uuid
  school_id             String             @db.Uuid
  student_id            String             @db.Uuid
  parent_id             String             @db.Uuid
  amount                Decimal            @db.Decimal(10, 2)
  receipt_url           String             @db.Text
  status                TopupRequestStatus @default(PENDING)
  payment_method        String?            @db.VarChar(20) // TRANSFERENCIA, NEQUI
  nequi_transaction_id  String?            @db.VarChar(100)
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  school  School  @relation(fields: [school_id], references: [id])
  student Student @relation(fields: [student_id], references: [id])
  parent  User    @relation(fields: [parent_id], references: [id])
}

// MÃ©todos de pago configurables por SUPER_ADMIN
model PaymentMethod {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique @db.VarChar(30) // NEQUI, BANCOLOMBIA, DAVIVIENDA
  label      String   @db.VarChar(50)         // "Nequi", "Bancolombia"
  icon       String   @db.VarChar(10)         // emoji
  color      String   @db.VarChar(20)         // hex color
  fields     Json     @default("[]")          // [{label, value}]
  active     Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// Suscripciones Web Push para notificaciones al padre
model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  endpoint   String   @unique @db.Text
  p256dh     String   @db.Text
  auth       String   @db.Text
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// MÃ³dulo de Proveedores B2B (Ley 2120 â€” trazabilidad Art. 32)
model Supplier {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  nit             String?  @db.VarChar(20)
  contact_name    String?  @db.VarChar(100)
  contact_phone   String?  @db.VarChar(20)
  contact_email   String?  @db.VarChar(255)
  city            String?  @db.VarChar(100)
  tech_sheet_url  String?  @db.VarChar(500)  // ficha tÃ©cnica
  tech_sheet_uploaded_at DateTime?
  is_verified     Boolean  @default(false)
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relacion inversa -- Brecha #6
  products   Product[]
}

// Modelos Ley 2120
model Allergy {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  severity    String   @default("moderate") @db.VarChar(20)
  description String?  @db.Text

  student_allergies StudentAllergy[]
  product_allergies ProductAllergy[]
}

model StudentAllergy {
  student_id   String   @db.Uuid
  allergy_id   String   @db.Uuid
  notes        String?  @db.Text
  diagnosed_at DateTime? @db.Date

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  allergy Allergy @relation(fields: [allergy_id], references: [id], onDelete: Cascade)

  @@id([student_id, allergy_id])
}

model ProductAllergy {
  product_id String @db.Uuid
  allergy_id String @db.Uuid

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  allergy Allergy @relation(fields: [allergy_id], references: [id], onDelete: Cascade)

  @@id([product_id, allergy_id])
}

model NutritionDailyReport {
  id                String   @id @default(uuid()) @db.Uuid
  student_id        String   @db.Uuid
  report_date       DateTime @db.Date
  total_calories    Decimal  @default(0) @db.Decimal(8, 2)
  total_sugar_grams Decimal  @default(0) @db.Decimal(8, 2)
  total_sodium_mg   Decimal  @default(0) @db.Decimal(8, 2)
  green_items       Int      @default(0)
  yellow_items      Int      @default(0)
  red_items         Int      @default(0)
  alerts_triggered  Int      @default(0)
  created_at        DateTime @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, report_date])
}

// â”€â”€ Ley 1581/2012 â€” Habeas Data â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// Registro de auditorÃ­a: toda operaciÃ³n sobre datos personales (Accountability)
model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String?  @db.Uuid           // quiÃ©n hizo la acciÃ³n (null = sistema)
  role          String?  @db.VarChar(30)    // rol del operador
  action        String   @db.VarChar(30)    // CREATE | READ | UPDATE | DELETE | EXPORT | ANONYMIZE
  entity        String   @db.VarChar(50)    // tabla/colecciÃ³n afectada
  record_id     String?  @db.VarChar(100)   // ID del registro afectado
  fields        String[] @default([])       // campos consultados/modificados
  ip_address    String?  @db.VarChar(45)
  justification String?  @db.Text           // motivo (obligatorio para datos sensibles)
  created_at    DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([entity, record_id])
  @@index([user_id, created_at])
}

// Solicitudes ARCO: Acceso, RectificaciÃ³n, CancelaciÃ³n, OposiciÃ³n (Art. 13â€“15)
model ArcoRequest {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  type        String   @db.VarChar(20)   // ACCESS | RECTIFY | DELETE | OPPOSE
  description String?  @db.Text
  status      String   @default("PENDING") @db.VarChar(20) // PENDING | IN_PROGRESS | RESOLVED
  resolved_at DateTime?
  response    String?  @db.Text
  created_at  DateTime @default(now())

  @@index([user_id, status])
}

// â”€â”€ Chat Interno: Tendero â†” Padre â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// El tendero inicia el hilo; el padre responde. Vinculado opcionalmente a un pedido.

model ChatThread {
  id        String   @id @default(uuid()) @db.Uuid
  school_id String   @db.Uuid
  order_id  String?  @db.Uuid               // pedido relacionado (opcional)
  vendor_id String   @db.Uuid               // tendero que abre el hilo
  parent_id String   @db.Uuid               // padre destinatario
  subject   String   @db.VarChar(200)        // ej: "Novedad pedido del martes"
  status    String   @default("OPEN") @db.VarChar(20) // OPEN | CLOSED | RESOLVED
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  school   School      @relation(fields: [school_id], references: [id])
  order    LunchOrder? @relation(fields: [order_id], references: [id])
  vendor   User        @relation("VendorThreads", fields: [vendor_id], references: [id])
  parent   User        @relation("ParentThreads", fields: [parent_id], references: [id])
  messages ChatMessage[]

  @@index([school_id, status])
  @@index([vendor_id])
  @@index([parent_id])
  @@index([order_id])
}

model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  thread_id  String   @db.Uuid
  sender_id  String   @db.Uuid
  content    String   @db.VarChar(1000)     // mÃ¡ximo 1000 caracteres
  read_at    DateTime?                       // null = no leÃ­do
  created_at DateTime @default(now())

  thread ChatThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [sender_id], references: [id])

  @@index([thread_id, created_at])
  @@index([sender_id])
}

// â”€â”€ Leads: Colegios interesados desde la landing â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
model SchoolLead {
  id              String   @id @default(uuid()) @db.Uuid
  school_name     String   @db.VarChar(200)        // Nombre del colegio
  nit             String?  @db.VarChar(20)          // NIT (opcional)
  city            String   @db.VarChar(100)
  contact_name    String   @db.VarChar(200)         // Nombre del administrador
  contact_email   String   @db.VarChar(255)
  contact_phone   String?  @db.VarChar(20)
  students_count  Int?                               // NÃºmero aproximado de estudiantes
  plan_interest   String   @db.VarChar(20)          // "COMMISSION" | "MONTHLY"
  message         String?  @db.Text                 // Mensaje adicional
  status          String   @default("NEW") @db.VarChar(20) // NEW | CONTACTED | DEMO | CLOSED
  notes           String?  @db.Text                 // Notas internas del super admin
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([status])
  @@index([created_at])
}


