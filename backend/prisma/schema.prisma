generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
}

enum UserRole {
  PARENT
  VENDOR
  SCHOOL_ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  TOPUP
  CHARGE
  REFUND
  ADJUSTMENT
}

enum TopupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NutritionalLevel {
  LEVEL_1  // Sin sellos — producto ideal
  LEVEL_2  // Con advertencias
}

enum ProductForm {
  SOLID
  LIQUID
}

model School {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(200)
  nit        String?  @unique @db.VarChar(20)
  city       String   @db.VarChar(100)
  department String?  @db.VarChar(100) // Departamento (e.g. "Antioquia")
  address    String?  @db.Text
  phone        String?  @db.VarChar(20)
  country_code String?  @default("+57") @db.VarChar(5)
  email        String?  @db.VarChar(255)
  logo_url   String?  @db.Text
  plan       PlanType @default(BASIC)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  users          User[]
  students       Student[]
  stores         Store[]
  lunch_orders   LunchOrder[]
  transactions   Transaction[]
  topup_requests TopupRequest[]
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  school_id     String?  @db.Uuid
  email         String   @unique @db.VarChar(255)
  phone         String?  @db.VarChar(20)
  country_code  String?  @default("+57") @db.VarChar(5)
  password_hash String?  @db.Text
  google_id     String?  @unique @db.VarChar(100)
  auth_provider String   @default("local") @db.VarChar(20)
  role          UserRole
  full_name     String   @db.VarChar(200)
  avatar_url    String?  @db.Text
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  school         School?             @relation(fields: [school_id], references: [id])
  students       Student[]           @relation("ParentToStudent")
  deliveries     LunchOrder[]        @relation("DeliveredBy")
  refresh_tokens   RefreshToken[]
  reset_tokens     PasswordResetToken[]
  topup_requests   TopupRequest[]
  push_subscriptions PushSubscription[]
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.Text
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([token_hash])
}

model Student {
  id          String   @id @default(uuid()) @db.Uuid
  school_id   String   @db.Uuid
  parent_id   String   @db.Uuid
  national_id String?  @db.VarChar(20)
  full_name   String   @db.VarChar(200)
  grade       String?  @db.VarChar(10)
  photo_url   String?  @db.Text
  balance     Decimal  @default(0.00) @db.Decimal(10, 2)
  delivery_code String? @db.VarChar(6)
  daily_spending_limit Decimal @default(15000.00) @db.Decimal(10, 2)
  active      Boolean  @default(true)
  created_at  DateTime @default(now())

  school         School        @relation(fields: [school_id], references: [id])
  parent         User          @relation("ParentToStudent", fields: [parent_id], references: [id])
  lunch_orders   LunchOrder[]
  transactions   Transaction[]
  topup_requests TopupRequest[]
  allergies      StudentAllergy[]
  nutrition_reports NutritionDailyReport[]

  @@unique([school_id, national_id])
}

model Store {
  id         String   @id @default(uuid()) @db.Uuid
  school_id  String   @db.Uuid
  name       String   @db.VarChar(200)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  school         School         @relation(fields: [school_id], references: [id])
  lunch_orders   LunchOrder[]
  store_products StoreProduct[]
}

// Categorías de productos — CRUD dinámico
model ProductCategory {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique @db.VarChar(50)   // slug: "almuerzo", "bebida", etc.
  label      String   @db.VarChar(100)           // display: "Almuerzos", "Bebidas"
  icon       String?  @db.VarChar(10)            // emoji icon
  color      String?  @db.VarChar(20)            // hex color
  sort_order Int      @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now())
}

// Catálogo maestro global — administrado por SUPER_ADMIN
model Product {
  id                   String          @id @default(uuid()) @db.Uuid
  name                 String          @db.VarChar(200)
  description          String?         @db.Text
  base_price           Decimal         @db.Decimal(10, 2)
  image_url            String?         @db.Text
  category             String?         @db.VarChar(50)
  is_healthy           Boolean         @default(true)
  customizable_options String[]        @default([])

  // ── Ley 2120 / Resolución 2492 de 2022 ──
  product_form           ProductForm     @default(SOLID)
  nutritional_level      NutritionalLevel @default(LEVEL_1) // computado por NutritionalClassifier
  sodium_per_100         Decimal?        @db.Decimal(8, 2)  // mg por 100g o 100ml
  added_sugars_pct       Decimal?        @db.Decimal(5, 2)  // % energía azúcares añadidos
  saturated_fat_pct      Decimal?        @db.Decimal(5, 2)  // % energía grasas saturadas
  trans_fat_pct          Decimal?        @db.Decimal(5, 2)  // % energía grasas trans
  has_sweeteners         Boolean         @default(false)
  // Sellos computados (solo escritura por NutritionalClassifier)
  seal_sodium            Boolean         @default(false)
  seal_sugars            Boolean         @default(false)
  seal_saturated_fat     Boolean         @default(false)
  seal_trans_fat         Boolean         @default(false)
  seal_sweeteners        Boolean         @default(false)
  // Trazabilidad
  supplier_tech_sheet_url String?        @db.VarChar(500)
  last_nutritional_audit  DateTime?

  active               Boolean         @default(true)
  created_at           DateTime        @default(now())

  store_products StoreProduct[]
  allergens      ProductAllergy[]
}

// Pivot: qué productos ofrece cada tienda, con precio y stock propios
model StoreProduct {
  id         String   @id @default(uuid()) @db.Uuid
  store_id   String   @db.Uuid
  product_id String   @db.Uuid
  price      Decimal? @db.Decimal(10, 2)  // null = usar base_price del catálogo
  stock      Int?                          // null = sin límite
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  store       Store       @relation(fields: [store_id], references: [id])
  product     Product     @relation(fields: [product_id], references: [id])
  order_items OrderItem[]

  @@unique([store_id, product_id])
}

model LunchOrder {
  id             String      @id @default(uuid()) @db.Uuid
  school_id      String      @db.Uuid
  student_id     String      @db.Uuid
  store_id       String      @db.Uuid
  scheduled_date DateTime    @db.Date
  status         OrderStatus @default(PENDING)
  total_amount   Decimal     @db.Decimal(10, 2)
  delivered_at   DateTime?
  delivered_by   String?     @db.Uuid
  otp_verified   Boolean     @default(false)
  otp_code       String?     @db.VarChar(6)
  otp_expires_at DateTime?
  notes          String?     @db.Text
  // ── Ley 2120 compliance ──
  is_seal_free        Boolean  @default(false)  // todos los productos level_1
  has_sweetener_alert Boolean  @default(false)  // algún producto con edulcorantes
  seal_summary        Json     @default("{}")
  compliance_score    Int      @default(100)    // 0-100
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  school      School        @relation(fields: [school_id], references: [id])
  student     Student       @relation(fields: [student_id], references: [id])
  store       Store         @relation(fields: [store_id], references: [id])
  deliverer   User?         @relation("DeliveredBy", fields: [delivered_by], references: [id])
  order_items OrderItem[]
  Transaction Transaction[]
}

model OrderItem {
  id               String  @id @default(uuid()) @db.Uuid
  order_id         String  @db.Uuid
  store_product_id String  @db.Uuid
  quantity         Int     @default(1) @db.SmallInt
  unit_price       Decimal @db.Decimal(10, 2)
  subtotal         Decimal @db.Decimal(10, 2)
  customizations   String[] @default([])

  order         LunchOrder   @relation(fields: [order_id], references: [id])
  store_product StoreProduct @relation(fields: [store_product_id], references: [id])
}

model Transaction {
  id             String          @id @default(uuid()) @db.Uuid
  school_id      String          @db.Uuid
  student_id     String          @db.Uuid
  type           TransactionType
  amount         Decimal         @db.Decimal(10, 2)
  balance_after  Decimal         @db.Decimal(10, 2)
  payment_method String?         @db.VarChar(50)
  gateway_ref    String?         @db.VarChar(100)
  order_id       String?         @db.Uuid
  created_at     DateTime        @default(now())

  school  School      @relation(fields: [school_id], references: [id])
  student Student     @relation(fields: [student_id], references: [id])
  order   LunchOrder? @relation(fields: [order_id], references: [id])
}

model PasswordResetToken {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @db.Text
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([token_hash])
}

model TopupRequest {
  id                    String             @id @default(uuid()) @db.Uuid
  school_id             String             @db.Uuid
  student_id            String             @db.Uuid
  parent_id             String             @db.Uuid
  amount                Decimal            @db.Decimal(10, 2)
  receipt_url           String             @db.Text
  status                TopupRequestStatus @default(PENDING)
  payment_method        String?            @db.VarChar(20) // TRANSFERENCIA, NEQUI
  nequi_transaction_id  String?            @db.VarChar(100)
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  school  School  @relation(fields: [school_id], references: [id])
  student Student @relation(fields: [student_id], references: [id])
  parent  User    @relation(fields: [parent_id], references: [id])
}

// Métodos de pago configurables por SUPER_ADMIN
model PaymentMethod {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique @db.VarChar(30) // NEQUI, BANCOLOMBIA, DAVIVIENDA
  label      String   @db.VarChar(50)         // "Nequi", "Bancolombia"
  icon       String   @db.VarChar(10)         // emoji
  color      String   @db.VarChar(20)         // hex color
  fields     Json     @default("[]")          // [{label, value}]
  active     Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// Suscripciones Web Push para notificaciones al padre
model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  endpoint   String   @unique @db.Text
  p256dh     String   @db.Text
  auth       String   @db.Text
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// Módulo de Proveedores B2B (Ley 2120 — trazabilidad Art. 32)
model Supplier {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  nit             String?  @db.VarChar(20)
  contact_name    String?  @db.VarChar(100)
  contact_phone   String?  @db.VarChar(20)
  contact_email   String?  @db.VarChar(255)
  city            String?  @db.VarChar(100)
  tech_sheet_url  String?  @db.VarChar(500)  // ficha técnica
  tech_sheet_uploaded_at DateTime?
  is_verified     Boolean  @default(false)
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

// Modelos Ley 2120
model Allergy {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  severity    String   @default("moderate") @db.VarChar(20)
  description String?  @db.Text

  student_allergies StudentAllergy[]
  product_allergies ProductAllergy[]
}

model StudentAllergy {
  student_id   String   @db.Uuid
  allergy_id   String   @db.Uuid
  notes        String?  @db.Text
  diagnosed_at DateTime? @db.Date

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  allergy Allergy @relation(fields: [allergy_id], references: [id], onDelete: Cascade)

  @@id([student_id, allergy_id])
}

model ProductAllergy {
  product_id String @db.Uuid
  allergy_id String @db.Uuid

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  allergy Allergy @relation(fields: [allergy_id], references: [id], onDelete: Cascade)

  @@id([product_id, allergy_id])
}

model NutritionDailyReport {
  id                String   @id @default(uuid()) @db.Uuid
  student_id        String   @db.Uuid
  report_date       DateTime @db.Date
  total_calories    Decimal  @default(0) @db.Decimal(8, 2)
  total_sugar_grams Decimal  @default(0) @db.Decimal(8, 2)
  total_sodium_mg   Decimal  @default(0) @db.Decimal(8, 2)
  green_items       Int      @default(0)
  yellow_items      Int      @default(0)
  red_items         Int      @default(0)
  alerts_triggered  Int      @default(0)
  created_at        DateTime @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, report_date])
}
